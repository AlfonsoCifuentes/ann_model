# Environment Variables
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_ANALYTICS_DOMAIN=your-domain.com
FORMSPREE_ID=your-formspree-id

# Database
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.example.mongodb.net/ann_model?retryWrites=true&w=majority

# Cloudinary (for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# NextAuth (if using authentication)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Public URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Contact Information (replace with actual values)
CONTACT_EMAIL=contact@ananicoleta.com
PRESS_EMAIL=press@ananicoleta.com
AGENCY_NAME=Ana Nicoleta Management

# Social Media URLs
INSTAGRAM_URL=https://instagram.com/ann__siedad.7
TIKTOK_URL=https://tiktok.com/@your-username
IMDB_URL=https://imdb.com/name/your-profile
YOUTUBE_URL=https://youtube.com/@your-channel

# Model Information
MODEL_NAME=Ana Nicoleta de Pedro Sanchez
BIO_SHORT_ES=Modelo profesional y actriz con experiencia internacional en moda y cine
BIO_SHORT_EN=Professional model and actress with international experience in fashion and film
